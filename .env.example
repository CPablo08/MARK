# Copy to .env and fill in your keys
DATABASE_URL=sqlite+aiosqlite:///./backend/mark.db
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
# GitHub (chat can list repos / your account when set)
GITHUB_TOKEN=
# Web browse/search uses Playwright — run: make playwright-install
# Open links in your default browser (Safari/Chrome) via open_website tool
BROWSER_OPEN_ENABLED=true

# Supervised email (MARK asks you to Approve before sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Supervised SMS / calls (optional — Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VOICE_TWIML_URL=

# Terminal tool: commands run in sandbox/ by default
# TERMINAL_ALLOW_OUTSIDE_SANDBOX=false
# Whisper STT (recommended): set OPENAI_API_KEY and WHISPER_BACKEND=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ELEVENLABS_API_KEY=
# Voice — JARVIS-style British male (ElevenLabs "Daniel")
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# Speech rate (0.7–1.25). ~0.95–1.0 = measured JARVIS pace
ELEVENLABS_SPEED=1.08
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
WHISPER_BACKEND=openai
WHISPER_MODEL=base
SAFETY_DEFAULT_MODE=assisted
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,tauri://localhost,http://127.0.0.1:5173
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# Frontend (apps/desktop/.env)
# VITE_API_URL=http://127.0.0.1:8000
